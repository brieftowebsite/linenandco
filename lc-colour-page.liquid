</style>

{% schema %}
{
  "name": "LC colour page",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "colour",
      "label": "Colour page",
      "options": [
        {
          "value": "hub",
          "label": "Shop by colour hub"
        },
        {
          "value": "white",
          "label": "White"
        },
        {
          "value": "cream",
          "label": "Cream"
        },
        {
          "value": "stone",
          "label": "Stone"
        },
        {
          "value": "grey",
          "label": "Grey"
        },
        {
          "value": "duck_egg",
          "label": "Duck egg"
        }
      ],
      "default": "hub"
    }
  ],
  "presets": [
    {
      "name": "LC colour page"
