        "richtext_bC9ciE": {
          "type": "richtext",
          "settings": {
            "content": "<p>Welcome to Linen and Co Support. Here you'll find answers to common questions about our products, ordering, delivery, care, and trade services. </p><p>If you need further assistance, please don’t hesitate to contact us directly via email, phone, or WhatsApp. We’re here to help!</p>"
          }
        }
      },
