{%- comment -%}
  ============================================================
  SNIPPET: lc-contact-cta.liquid
  Purpose: Renders the PDP contact and support CTA section.

  Usage:
    {%- render 'lc-contact-cta',
      product: product
    -%}

  Behavior:
    - Shows a support message at the end of the PDP anchor sections.
    - Links customers to contact, trade registration, and WhatsApp.
    - Uses high-contrast CTA styling for easy scanning.

  Assets:
    - Styles: assets/lc-main-product.css
  ============================================================
{%- endcomment -%}

<section class="lc-profile-section lc-contact-cta" id="lc-contact-cta">
  <div class="lc-contact-cta__inner">
    <span class="lc-contact-cta__eyebrow">We're Here To Help</span>

    <h2 class="lc-contact-cta__heading">Need Advice?</h2>

    <p class="lc-contact-cta__text">
      Our team is on hand to help you find the right linen for your property, project, or home.
    </p>

    <div class="lc-contact-cta__buttons">
      <a href="/pages/contact" class="lc-contact-cta__btn" aria-label="Contact Linen and Co">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
        Contact Us
      </a>

      <a href="/pages/trade-registration-form" class="lc-contact-cta__btn" aria-label="Register for a Linen and Co trade account">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        Register For Trade
      </a>

      <a
        href="https://wa.me/27662918292"
        class="lc-contact-cta__btn lc-contact-cta__btn--whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Chat with Linen and Co on WhatsApp"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"></path>
        </svg>
        Chat On WhatsApp
      </a>
    </div>
  </div>
</section>



