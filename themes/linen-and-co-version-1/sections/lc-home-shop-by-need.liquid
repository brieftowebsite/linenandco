{%- liquid
  assign heading = section.settings.heading | default: 'Essentials for better rooms'
  assign intro = section.settings.intro
-%}

{%- if section.blocks.size > 0 -%}
  <section class="lc-home-shop-by-need color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
    <div class="container">
      <div class="lc-home-shop-by-need__header">
        <div class="lc-home-shop-by-need__copy">
          <h2 id="lc-home-shop-by-need-heading-{{ section.id }}">{{ heading }}</h2>

          {%- if intro != blank -%}
            <p>{{ intro }}</p>
          {%- endif -%}
        </div>

        <nav class="lc-home-shop-by-need__nav" aria-labelledby="lc-home-shop-by-need-heading-{{ section.id }}">
          <ul class="unstyled-list" role="list">
            {%- for block in section.blocks -%}
              {%- liquid
                assign tile_link = block.settings.link
                assign title = block.settings.title | default: 'Shop'
              -%}

              <li>
                <a class="lc-home-shop-by-need__chip" href="{{ tile_link | default: routes.all_products_collection_url }}">
                  {{- title -}}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      </div>

      <div class="lc-home-shop-by-need__rail" data-lc-shop-by-need-rail>
        <div class="lc-home-shop-by-need__track" tabindex="0" data-lc-shop-by-need-track>
          {%- for block in section.blocks -%}
            {%- liquid
              assign image_asset = block.settings.image_asset | strip
              assign tile_link = block.settings.link
              assign image_alt = block.settings.image_alt | default: block.settings.title
            -%}

            <a class="lc-home-shop-by-need__tile" href="{{ tile_link | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
              {%- if image_asset != blank -%}
                <img
                  src="{{ image_asset | asset_url }}"
                  alt="{{ image_alt | escape }}"
                  width="1200"
                  height="1800"
                  loading="{% if forloop.index <= 2 %}eager{% else %}lazy{% endif %}"
                >
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <span class="lc-home-shop-by-need__tile-title">{{ block.settings.title }}</span>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>

        <div class="lc-home-shop-by-need__controls" data-lc-shop-by-need-controls aria-label="{{ heading | strip_html | escape }}">
          <button class="lc-home-shop-by-need__arrow" type="button" data-lc-shop-by-need-prev aria-label="Previous categories">
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path d="M15 18 9 12l6-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" />
            </svg>
          </button>

          <button class="lc-home-shop-by-need__arrow" type="button" data-lc-shop-by-need-next aria-label="Next categories">
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path d="m9 6 6 6-6 6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "LC shop by need",
  "class": "shopify-section--lc-home-shop-by-need",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Navigation label",
      "default": "Shop"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Categories"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Shop linen and home essentials by category, from bed and bath to table linen and window treatments."
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker",
          "default": "Shop"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Bed Linen"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Sheets, duvet covers and pillowcases."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "Theme asset filename",
          "default": "linen-and-co-shop-by-need-bed-linen.webp"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Crisp white bed linen on a guest-ready bed"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LC shop by need",
      "blocks": [
        {
          "type": "tile"
        },
        {
          "type": "tile",
          "settings": {
            "title": "Bath Linen",
            "text": "Towels, bath mats and guest-ready bathroom essentials.",
            "image_asset": "linen-and-co-shop-by-need-bath-linen.webp",
            "image_alt": "Neatly stacked white bath towels"
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "Duvets & Pillows",
            "text": "Duvet inners and pillows for comfortable rooms.",
            "image_asset": "linen-and-co-shop-by-need-duvets-pillows.webp",
            "image_alt": "White duvet inner and pillows in a studio arrangement"
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "Protectors",
            "text": "Mattress and pillow protection for everyday use.",
            "image_asset": "linen-and-co-shop-by-need-protectors.webp",
            "image_alt": "White quilted mattress and pillow protectors"
          }
        }
      ]
    }
  ]
}
{% endschema %}
