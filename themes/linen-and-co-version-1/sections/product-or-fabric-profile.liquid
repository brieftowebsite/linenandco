    .lc-profile-section { padding: 0 0 16px; }
    .lc-profile-section__inner { padding: 0 16px; }
    .lc-profile-section__split { grid-template-columns: 1fr; }
    .lc-profile-section__image { min-height: 240px; max-height: 320px; order: -1; }
    .lc-profile-section__text { padding: 20px 16px 16px; }
    .lc-profile-section__heading { font-size: 1rem; margin-bottom: 12px; }
    .lc-htm-steps { grid-template-columns: 1fr 1fr; gap: 16px; }
    .lc-contact-cta { padding: 40px 0 32px !important; }
    .lc-contact-cta__inner { padding: 0 16px; }
    .lc-contact-cta__buttons { flex-direction: row; justify-content: center; flex-wrap: wrap; }
    .lc-bullets li { font-size: 0.8rem !important; }
    .lc-body-text p,
    .lc-body-text li { font-size: 0.8rem !important; }
  }
</style>

<script>
(function() {
  var nav = document.getElementById('lc-anchor-nav');
  var shopNow = nav ? nav.querySelector('.lc-anchor-nav__link--shop') : null;
  if (shopNow) {
    shopNow.addEventListener('click', function(e) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
  var links = document.querySelectorAll('.lc-anchor-nav__link:not(.lc-anchor-nav__link--shop)');
  var sections = [];
  links.forEach(function(link) {
    var href = link.getAttribute('href');
    if (href && href.startsWith('#')) {
      var el = document.getElementById(href.replace('#', ''));
      if (el) sections.push({ el: el, link: link });
    }
  });
  if (!sections.length) return;
  window.addEventListener('scroll', function() {
    var scrollY = window.scrollY + 120;
    var current = sections[0];
    sections.forEach(function(s) {
      if (s.el.offsetTop <= scrollY) current = s;
    });
    links.forEach(function(l) { l.classList.remove('is-active'); });
    if (current) current.link.classList.add('is-active');
  }, { passive: true });

  var lightbox = document.getElementById('lc-lightbox');
  var lbImg = document.getElementById('lc-lightbox-img');
  var lbLabel = document.getElementById('lc-lightbox-label');
  var lbClose = document.getElementById('lc-lightbox-close');
  function openLightbox(src, label) {
    lbImg.src = src;
    lbImg.alt = label || '';
    lbLabel.textContent = label || '';
    lightbox.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    lightbox.classList.remove('is-open');
    document.body.style.overflow = '';
    lbImg.src = '';
  }
  document.querySelectorAll('.lc-compare-styles__img-wrap').forEach(function(el) {
    el.addEventListener('click', function() {
      openLightbox(el.dataset.zoom, el.dataset.label);
    });
  });
  if (lbClose) lbClose.addEventListener('click', closeLightbox);
  if (lightbox) lightbox.addEventListener('click', function(e) {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeLightbox();
  });
})();
</script>

