  .lc-contact-cta__buttons { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; }
  .lc-contact-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    font-weight: 550;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffffff;
    background: transparent;
    border: 2px solid rgba(255,255,255,0.45);
    padding: 12px 24px;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
