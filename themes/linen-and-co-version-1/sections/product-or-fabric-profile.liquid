  .lc-htm-note p {
    margin-bottom: 12px;
  }
  
  .lc-htm-buttons { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin-top: 24px; }

  /* ── PROFILE BUTTON ── */
  .lc-profile-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 550;
    letter-spacing: 0.06em;
    text-transform: uppercase;
