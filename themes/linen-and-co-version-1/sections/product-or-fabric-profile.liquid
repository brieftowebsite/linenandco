  .lc-htm-step { display: flex; flex-direction: column; gap: 12px; }
  .lc-htm-step__image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 2px;
    background: rgba(0,0,0,0.04);
  }
  .lc-htm-step__image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lc-htm-step__content { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 4px; }
  .lc-htm-step__number {
    display: inline-flex;
