  .lc-htm-note {
    margin: 16px auto;
    max-width: 1400px;
    padding: 12px 16px;
    background: rgba(0,0,0,0.03);
    font-size: 0.8rem;
    font-weight: 560;
    font-style: italic;
    color: rgba(0,0,0,0.80);
