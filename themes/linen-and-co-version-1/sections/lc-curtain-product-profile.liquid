{%- assign pp = product.metafields.custom.product_profile.value -%}
{%- assign htm = product.metafields.custom.how_to_measure.value -%}
{%- assign product_title_down = product.title | downcase -%}
{%- assign product_tags_down = product.tags | join: ' ' | downcase -%}
{%- assign is_ready_made_curtain = false -%}
{%- if product.template_suffix == 'lc-ready-made-curtain' or product_tags_down contains 'ready-made curtains' or product_tags_down contains 'ready made curtains' -%}
  {%- assign is_ready_made_curtain = true -%}
{%- endif -%}
{%- assign curtain_type = 'Sheer' -%}
{%- if product_title_down contains 'blockout' or product_title_down contains 'blackout' or product_tags_down contains 'blockout' or product_tags_down contains 'blackout' -%}
  {%- assign curtain_type = 'Blockout' -%}
{%- endif -%}
{%- assign current_heading = blank -%}
{%- if product_title_down contains 'eyelet' or product_tags_down contains 'eyelet' -%}
  {%- assign current_heading = 'Eyelet' -%}
{%- elsif product_title_down contains 'taped' or product_title_down contains 'tape' or product_tags_down contains 'taped' or product_tags_down contains 'tape curtain' -%}
  {%- assign current_heading = 'Taped' -%}
{%- endif -%}

{%- if is_ready_made_curtain -%}
  <section class="lc-curtain-profile" id="lc-curtain-profile-{{ section.id }}" data-section-id="{{ section.id }}">
    <div class="container container--xl">
      {%- if pp != blank -%}
        {%- render 'lc-product-description', pp: pp, product: product -%}
        {%- render 'lc-why-choose', pp: pp, product: product -%}
      {%- elsif product.description != blank -%}
        <section class="lc-profile-section lc-curtain-profile-intro" id="lc-curtain-overview">
          <div class="lc-profile-section__inner">
            <span class="lc-label">Curtain profile</span>
            <h2 class="lc-profile-section__heading">About this curtain</h2>
            <div class="rte">{{ product.description }}</div>
          </div>
        </section>
      {%- endif -%}
      {%- render 'lc-curtain-profile-facts', product: product, pp: pp, curtain_type: curtain_type, current_heading: current_heading -%}
      {%- if pp != blank -%}
        {%- render 'lc-ideal-uses', pp: pp, product: product -%}
      {%- endif -%}
      {%- render 'lc-curtain-heading-guide', product: product, current_heading: current_heading -%}
      {%- render 'lc-curtain-measure-guide', htm: htm -%}
      {%- if pp != blank -%}
        {%- render 'lc-care-strip', pp: pp, product: product -%}
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .lc-curtain-profile {
    background: #ffffff;
    color: rgba(0, 0, 0, 0.86);
  }

  .lc-curtain-profile .lc-profile-section {
    padding-block: 36px;
  }

  .lc-curtain-profile-facts,
  .lc-curtain-measure-guide {
    background: #f4f4f2;
  }

  .lc-curtain-profile-facts__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 24px 0 0;
    border-block: 1px solid rgba(0, 0, 0, 0.12);
  }

  .lc-curtain-profile-facts__item {
    display: grid;
    gap: 7px;
    min-width: 0;
    padding: 20px;
    border-left: 1px solid rgba(0, 0, 0, 0.12);
  }

  .lc-curtain-profile-facts__item:nth-child(4n + 1) {
    border-left: 0;
  }

  .lc-curtain-profile-facts__item dt {
    color: rgba(0, 0, 0, 0.5);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .lc-curtain-profile-facts__item dd {
    margin: 0;
    color: rgba(0, 0, 0, 0.86);
    font-size: 0.84rem;
    font-weight: 650;
    line-height: 1.42;
  }

  .lc-curtain-heading-guide__intro,
  .lc-curtain-measure-guide__intro {
    max-width: 720px;
    margin: 0;
    color: rgba(0, 0, 0, 0.68);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .lc-curtain-heading-guide__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 26px;
    border-block: 1px solid rgba(0, 0, 0, 0.12);
  }

  .lc-curtain-heading-option {
    min-width: 0;
    padding: 26px 28px 28px;
  }

  .lc-curtain-heading-option + .lc-curtain-heading-option {
    border-left: 1px solid rgba(0, 0, 0, 0.12);
  }

  .lc-curtain-heading-option__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    margin-bottom: 20px;
    overflow: hidden;
    background: #eeeeec;
  }

  .lc-curtain-heading-option__image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lc-curtain-heading-option__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .lc-curtain-heading-option h3 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .lc-curtain-heading-option__current {
    flex: 0 0 auto;
    padding: 5px 8px;
    background: #000000;
    color: #ffffff;
    font-size: 0.54rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
  }

  .lc-curtain-heading-option p {
    margin: 12px 0 0;
    color: rgba(0, 0, 0, 0.68);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .lc-curtain-heading-option ul {
    display: grid;
    gap: 7px;
    margin: 16px 0 0;
    padding-left: 1rem;
    color: rgba(0, 0, 0, 0.72);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .lc-curtain-measure-guide__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 24px;
    border-block: 1px solid rgba(0, 0, 0, 0.12);
  }

  .lc-curtain-measure-step {
    min-width: 0;
    padding: 24px;
  }

  .lc-curtain-measure-step + .lc-curtain-measure-step {
    border-left: 1px solid rgba(0, 0, 0, 0.12);
  }

  .lc-curtain-measure-step__number {
    display: inline-flex;
    margin-bottom: 16px;
    color: #000000;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .lc-curtain-measure-step h3 {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.25;
  }

  .lc-curtain-measure-step p {
    margin: 9px 0 0;
    color: rgba(0, 0, 0, 0.66);
    font-size: 0.8rem;
    line-height: 1.52;
  }

  .lc-curtain-measure-guide__note {
    max-width: 820px;
    margin: 22px 0 0;
    padding-left: 16px;
    border-left: 2px solid #000000;
    color: rgba(0, 0, 0, 0.72);
    font-size: 0.8rem;
    line-height: 1.55;
  }

  .lc-curtain-measure-guide__note > *:first-child {
    margin-top: 0;
  }

  .lc-curtain-measure-guide__note > *:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 999px) {
    .lc-curtain-profile .lc-profile-section {
      padding-block: 0 28px;
    }

    .lc-curtain-profile-facts,
    .lc-curtain-heading-guide,
    .lc-curtain-measure-guide {
      padding-top: 28px !important;
    }

    .lc-curtain-profile-facts__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .lc-curtain-profile-facts__item:nth-child(4n + 1) {
      border-left: 1px solid rgba(0, 0, 0, 0.12);
    }

    .lc-curtain-profile-facts__item:nth-child(2n + 1) {
      border-left: 0;
    }
  }

  @media screen and (max-width: 749px) {
    .lc-curtain-profile-facts__grid,
    .lc-curtain-heading-guide__grid,
    .lc-curtain-measure-guide__steps {
      grid-template-columns: 1fr;
    }

    .lc-curtain-profile-facts__item,
    .lc-curtain-profile-facts__item:nth-child(4n + 1),
    .lc-curtain-profile-facts__item:nth-child(2n + 1),
    .lc-curtain-heading-option + .lc-curtain-heading-option,
    .lc-curtain-measure-step + .lc-curtain-measure-step {
      border-left: 0;
    }

    .lc-curtain-profile-facts__item + .lc-curtain-profile-facts__item,
    .lc-curtain-heading-option + .lc-curtain-heading-option,
    .lc-curtain-measure-step + .lc-curtain-measure-step {
      border-top: 1px solid rgba(0, 0, 0, 0.12);
    }

    .lc-curtain-profile-facts__item,
    .lc-curtain-heading-option,
    .lc-curtain-measure-step {
      padding: 18px 0;
    }

    .lc-curtain-heading-guide__intro,
    .lc-curtain-measure-guide__intro,
    .lc-curtain-heading-option p,
    .lc-curtain-measure-step p,
    .lc-curtain-measure-guide__note {
      font-size: 0.76rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LC Curtain Profile",
  "settings": []
}
{% endschema %}
