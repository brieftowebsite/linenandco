{%- if section.settings.show_image == false or collection.image == blank and section.settings.image == blank -%}
  {%- assign show_image = false -%}
{%- else -%}
  {%- assign show_image = true -%}
{%- endif -%}

{%- capture collection_breadcrumb -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="breadcrumb breadcrumb--floating" aria-label="{{ 'general.breadcrumb.label' | t | escape }}">
      <ol class="breadcrumb__list unstyled-list">
        <li class="breadcrumb__list-item">
          <a href="{{ routes.root_url }}" class="smallcaps {% unless show_image %}link-faded{% endunless %}">{{ 'general.breadcrumb.home' | t }}</a>
        </li>

        <li class="breadcrumb__list-item">
          <a href="{{ routes.all_products_collection_url }}" class="smallcaps {% unless show_image %}link-faded{% endunless %}">{{ 'general.breadcrumb.shop' | t }}</a>
        </li>

        <li class="breadcrumb__list-item">
          <a href="{{ collection.url }}" aria-current="page" class="smallcaps {% unless show_image %}link-faded{% endunless %}">{{ collection.title }}</a>
        </li>
      </ol>
    </nav>
  {%- endif -%}
{%- endcapture -%}

{%- capture collection_heading -%}
  {%- if section.settings.show_collection_title -%}
    <h1 class="h1">{{ collection.title }}</h1>
  {%- endif -%}
{%- endcapture -%}

{%- capture collection_description -%}
  {%- if section.settings.show_collection_description and collection.description != blank -%}
    {%- capture collection_desc_mobile_style -%}
<style>
@media (max-width: 749px) {
  .collection-desc-mobile { font-size: 10px !important; line-height: 1.4 !important; }
}
</style>
    {%- endcapture -%}

    {%- liquid
      assign collection_desc_mobile_style_compact = '<style>@media (max-width: 749px) { .collection-desc-mobile { font-size: 10px !important; line-height: 1.4 !important; } }</style>'
      assign clean_collection_description = collection.description
      assign clean_collection_description = clean_collection_description | replace: collection_desc_mobile_style, ''
      assign clean_collection_description = clean_collection_description | replace: collection_desc_mobile_style_compact, ''
      assign clean_collection_description = clean_collection_description | replace: '<div class="collection-desc-mobile" style="font-size: 12px; line-height: 1.5;">', '<div class="collection-desc-mobile">'
      assign clean_collection_description = clean_collection_description | replace: ' style="font-size: 12px; line-height: 1.5;"', ''
    -%}

    <div class="lc-collection-description__content rte">
      {{- clean_collection_description -}}
    </div>
  {%- endif -%}
{%- endcapture -%}

{%- assign text_alignment = section.settings.text_alignment | replace: 'left', 'start' | replace: 'right', 'end' -%}

{%- if show_image -%}
  <style>
    #shopify-section-{{ section.id }} {
      --content-over-media-overlay: {{ section.settings.overlay_color.rgb }} / {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      --content-over-media-content-max-width: var(--container-{{ section.settings.content_width }}-max-width);
    }
  </style>

  <collection-banner
    {% if section.settings.reveal %}
      reveal-on-scroll="true"
    {% endif %}
    class="collection-banner color-scheme color-scheme--{{ section.settings.color_scheme.id }}"
    {% if section.settings.allow_transparent_header %}
      allow-transparent-header
    {% endif %}
  >
    {%- unless section.settings.allow_transparent_header -%}
      {{- collection_breadcrumb -}}
    {%- endunless -%}

    <div class="content-over-media content-over-media--{{ section.settings.image_size }}">
      {%- capture picture_content -%}
        <picture>
          {%- if section.settings.mobile_image != blank -%}
            <source
                media="(max-width: 699px)"
                srcset="{{ section.settings.mobile_image | image_url: width: 400 }} 400w, {{ section.settings.mobile_image | image_url: width: 600 }} 600w, {{ section.settings.mobile_image | image_url: width: 800 }} 800w, {{ section.settings.mobile_image | image_url: width: 1000 }} 1000w"
                width="{{ section.settings.mobile_image.width }}"
                height="{{ section.settings.mobile_image.height }}"
            >
          {%- endif -%}

          {%- assign image = section.settings.image | default: collection.image -%}
          {{- image | image_url: width: image.width | image_tag: fetchpriority: 'high', widths: '300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200' -}}
        </picture>
      {%- endcapture -%}

      {%- if section.settings.enable_parallax -%}
        <image-parallax class="contents">
          {{- picture_content -}}
        </image-parallax>
      {%- else -%}
        {{- picture_content -}}
      {%- endif -%}

      <div class="prose place-self-center-{{ text_alignment }} text-{{ text_alignment }}">
        {{ collection_heading }}
      </div>
    </div>
  </collection-banner>

  {%- if collection_description != blank -%}
    <div class="lc-collection-description color-scheme color-scheme--{{ section.settings.description_color_scheme.id }}">
      <div class="container container--lg">
        <div class="lc-collection-description__inner">
          <div class="lc-collection-description__layout">
            <p class="lc-collection-description__eyebrow">{{ section.settings.description_eyebrow }}</p>
            {{- collection_description -}}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
{%- elsif collection_heading != blank or collection_description != blank -%}
  <div class="color-scheme color-scheme--{{ section.settings.color_scheme.id }} lc-collection-text-hero{% if collection.handle == 'bed-linen-sale' %} lc-collection-text-hero--sale{% endif %}">
    <div class="lc-collection-text-hero__inner">
      <div class="container container--lg container--align-{{ text_alignment }}">
        {{- collection_breadcrumb -}}

        <div class="lc-collection-text-hero__content prose text-{{ text_alignment }}">
          {{- collection_heading -}}
          {{- collection_description -}}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

<style>
  #shopify-section-{{ section.id }} .lc-collection-description {
    padding: clamp(24px, 4vw, 46px) 0;
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero {
    background: rgb(var(--background));
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero__inner {
    padding-block: clamp(1.75rem, 3.8vw, 3.2rem) clamp(0.9rem, 1.9vw, 1.45rem);
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero__content {
    max-width: 58rem;
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero__content .h1 {
    margin: 0;
    max-width: 14ch;
    font-size: clamp(1.65rem, 2.7vw, 2.6rem);
    font-weight: var(--heading-font-weight);
    letter-spacing: 0;
    line-height: 1.05;
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero--sale .lc-collection-text-hero__inner {
    padding-block: clamp(1.75rem, 3vw, 2.4rem) clamp(1rem, 1.8vw, 1.45rem);
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero--sale .container {
    max-width: none;
    margin-inline: var(--container-gutter);
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero--sale .lc-collection-text-hero__content {
    width: 100%;
    max-width: none;
    margin-inline: auto;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero--sale .lc-collection-text-hero__content .h1 {
    max-width: none;
    margin-inline: auto;
    font-size: clamp(2.35rem, 4.2vw, 4rem);
    line-height: 1;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero__content .lc-collection-description__content {
    max-width: 45rem;
    margin-block-start: clamp(0.75rem, 1.5vw, 1.1rem);
    color: rgb(var(--text-color) / 0.68);
    font-size: clamp(0.82rem, 0.9vw, 0.92rem);
    font-weight: 400;
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero__content .lc-collection-description__content :is(p, ul, ol) {
    margin-block: 0.45rem 0;
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero__content .lc-collection-description__content :is(h2, h3, h4) {
    margin-block: 0.75rem 0.3rem;
    color: rgb(var(--text-color));
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.35;
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero__content .lc-collection-description__content strong {
    color: rgb(var(--text-color));
    font-weight: 550;
  }

  #shopify-section-{{ section.id }} .lc-collection-text-hero__content .lc-collection-description__content ul,
  #shopify-section-{{ section.id }} .lc-collection-text-hero__content .lc-collection-description__content ol {
    padding-inline-start: 1.15rem;
  }

  #shopify-section-{{ section.id }} .lc-collection-description__inner {
    max-width: 1120px;
    margin-inline: auto;
    border-block: 1px solid rgb(var(--text-color) / 0.1);
    padding: clamp(20px, 3vw, 34px) 0;
  }

  #shopify-section-{{ section.id }} .lc-collection-description__layout {
    display: grid;
    grid-template-columns: minmax(130px, 0.26fr) minmax(0, 1fr);
    gap: clamp(18px, 5vw, 64px);
    align-items: start;
  }

  #shopify-section-{{ section.id }} .lc-collection-description__eyebrow {
    margin: 0;
    padding-top: 0.32rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--text-color) / 0.58);
  }

  #shopify-section-{{ section.id }} .lc-collection-description__eyebrow::after {
    content: "";
    display: block;
    width: 42px;
    height: 1px;
    margin-top: 14px;
    background: rgb(var(--text-color) / 0.28);
  }

  #shopify-section-{{ section.id }} .lc-collection-description__content {
    max-width: 790px;
    font-size: 0.96rem;
    line-height: 1.72;
    color: rgb(var(--text-color) / 0.78);
  }

  #shopify-section-{{ section.id }} .lc-collection-description__content > :first-child {
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .lc-collection-description__content :is(h2, h3, h4) {
    margin-block: 1.15em 0.45em;
    color: rgb(var(--text-color));
  }

  #shopify-section-{{ section.id }} .lc-collection-description__content p {
    margin-block: 0 0.85em;
  }

  #shopify-section-{{ section.id }} .lc-collection-description__content a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .lc-collection-text-hero__inner {
      padding-block: 1.65rem 0.75rem;
    }

    #shopify-section-{{ section.id }} .lc-collection-text-hero__content .h1 {
      max-width: 14ch;
      font-size: clamp(1.5rem, 5.6vw, 2.15rem);
      line-height: 1.05;
    }

    #shopify-section-{{ section.id }} .lc-collection-text-hero__content .lc-collection-description__content {
      margin-block-start: 0.7rem;
      font-size: 0.84rem;
      line-height: 1.48;
    }

    #shopify-section-{{ section.id }} .lc-collection-text-hero__content .lc-collection-description__content :is(h2, h3, h4) {
      font-size: 0.92rem;
    }

    #shopify-section-{{ section.id }} .lc-collection-description {
      padding: 20px 0 26px;
    }

    #shopify-section-{{ section.id }} .lc-collection-description__inner {
      padding: 18px 0;
    }

    #shopify-section-{{ section.id }} .lc-collection-description__layout {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .lc-collection-description__eyebrow::after {
      margin-top: 10px;
    }

    #shopify-section-{{ section.id }} .lc-collection-description__content {
      font-size: 0.9rem;
      line-height: 1.68;
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.collection_banner.name",
  "class": "shopify-section--collection-banner",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-4"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:global.image.image",
      "info": "t:sections.collection_banner.image_info"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "t:global.image.mobile_image",
      "info": "t:sections.collection_banner.mobile_image_info"
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "t:global.image.size",
      "options": [
        {
          "value": "auto",
          "label": "t:global.sizes.original_image_ratio"
        },
        {
          "value": "xs",
          "label": "t:global.sizes.x_small"
        },
        {
          "value": "sm",
          "label": "t:global.sizes.small"
        },
        {
          "value": "md",
          "label": "t:global.sizes.medium"
        },
        {
          "value": "lg",
          "label": "t:global.sizes.large"
        }
      ],
      "info": "t:global.image.ratio_avoid_cropping_info",
      "default": "auto"
    },
    {
      "type": "checkbox",
      "id": "allow_transparent_header",
      "label": "t:global.section.allow_transparent_header",
      "info": "t:global.section.allow_transparent_header_info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.collection_banner.show_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "reveal",
      "label": "t:sections.collection_banner.reveal",
      "default": true,
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "t:sections.collection_banner.enable_parallax",
      "info": "t:sections.collection_banner.enable_parallax_info",
      "default": true,
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "checkbox",
      "id": "show_collection_title",
      "label": "t:sections.collection_banner.show_collection_title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "label": "t:sections.collection_banner.show_collection_description",
      "default": true
    },
    {
      "type": "text",
      "id": "description_eyebrow",
      "label": "Description eyebrow",
      "default": "Collection overview"
    },
    {
      "type": "color_scheme",
      "id": "description_color_scheme",
      "label": "Description color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "t:sections.collection_banner.show_breadcrumb",
      "default": true
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "t:global.sizes.content_width",
      "options": [
        {
          "value": "xxs",
          "label": "t:global.sizes.xx_small"
        },
        {
          "value": "xs",
          "label": "t:global.sizes.x_small"
        },
        {
          "value": "sm",
          "label": "t:global.sizes.small"
        },
        {
          "value": "md",
          "label": "t:global.sizes.medium"
        },
        {
          "value": "lg",
          "label": "t:global.sizes.large"
        },
        {
          "value": "xl",
          "label": "t:global.sizes.x_large"
        }
      ],
      "default": "xs"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "label": "t:global.text.alignment",
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:global.colors.category",
      "info": "t:sections.collection_banner.colors_category_info"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:global.colors.overlay_color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:global.colors.overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 30
    }
  ]
}
{% endschema %}
