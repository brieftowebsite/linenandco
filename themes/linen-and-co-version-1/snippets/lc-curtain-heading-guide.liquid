{% doc %}
Renders the Eyelet and Taped comparison stored on curtain_profile.

@param {object} profile - Curtain profile metaobject.
{% enddoc %}

{%- liquid
  assign label = profile.heading_style_label | default: 'Heading Style'
  assign heading = profile.heading_style_heading
  assign current_heading = profile.current_heading_style.value | default: profile.current_heading_style | downcase
  assign eyelet_image = profile.eyelet_image
  assign eyelet_content = profile.eyelet_content
  assign taped_image = profile.taped_image
  assign taped_content = profile.taped_content

  assign has_heading_content = false
  if heading != blank or eyelet_image != blank or eyelet_content != blank or taped_image != blank or taped_content != blank
    assign has_heading_content = true
  endif
-%}

{%- if has_heading_content -%}
  <section class="lc-curtain-section lc-curtain-heading-styles" id="lc-curtain-heading-styles">
    <div class="lc-curtain-section__inner">
      <div class="lc-curtain-title-row lc-curtain-title-row--center">
        <span class="lc-curtain-kicker">{{ label | escape }}</span>
        {%- if heading != blank -%}<h2>{{ heading | escape }}</h2>{%- endif -%}
      </div>

      <div class="lc-curtain-heading-grid">
        {%- if eyelet_image != blank or eyelet_content != blank -%}
          <article class="lc-curtain-heading-card{% if current_heading == 'eyelet' %} is-active{% endif %}">
            {%- if eyelet_image != blank -%}
              <a class="lc-curtain-heading-card__image" href="{{ eyelet_image | image_url: width: 2400 }}" data-lc-profile-zoom data-pswp-width="{{ eyelet_image.width }}" data-pswp-height="{{ eyelet_image.height }}" aria-label="Zoom image: Eyelet heading detail">
                <img
                  src="{{ eyelet_image | image_url: width: 900 }}"
                  srcset="{{ eyelet_image | image_url: width: 500 }} 500w, {{ eyelet_image | image_url: width: 700 }} 700w, {{ eyelet_image | image_url: width: 900 }} 900w"
                  sizes="(max-width: 749px) 100vw, 50vw"
                  alt="Eyelet heading detail for {{ profile.product_name | escape }}"
                  width="{{ eyelet_image.width }}"
                  height="{{ eyelet_image.height }}"
                  loading="lazy">
              </a>
            {%- endif -%}
            <div class="lc-curtain-heading-card__top">
              <h3>Eyelet</h3>
              {%- if current_heading == 'eyelet' -%}<span>Current style</span>{%- endif -%}
            </div>
            {%- if eyelet_content != blank -%}<div class="lc-curtain-heading-card__copy rte">{{ eyelet_content | metafield_tag }}</div>{%- endif -%}
          </article>
        {%- endif -%}

        {%- if taped_image != blank or taped_content != blank -%}
          <article class="lc-curtain-heading-card{% if current_heading == 'taped' %} is-active{% endif %}">
            {%- if taped_image != blank -%}
              <a class="lc-curtain-heading-card__image" href="{{ taped_image | image_url: width: 2400 }}" data-lc-profile-zoom data-pswp-width="{{ taped_image.width }}" data-pswp-height="{{ taped_image.height }}" aria-label="Zoom image: Taped heading detail">
                <img
                  src="{{ taped_image | image_url: width: 900 }}"
                  srcset="{{ taped_image | image_url: width: 500 }} 500w, {{ taped_image | image_url: width: 700 }} 700w, {{ taped_image | image_url: width: 900 }} 900w"
                  sizes="(max-width: 749px) 100vw, 50vw"
                  alt="Taped heading detail for {{ profile.product_name | escape }}"
                  width="{{ taped_image.width }}"
                  height="{{ taped_image.height }}"
                  loading="lazy">
              </a>
            {%- endif -%}
            <div class="lc-curtain-heading-card__top">
              <h3>Taped</h3>
              {%- if current_heading == 'taped' -%}<span>Current style</span>{%- endif -%}
            </div>
            {%- if taped_content != blank -%}<div class="lc-curtain-heading-card__copy rte">{{ taped_content | metafield_tag }}</div>{%- endif -%}
          </article>
        {%- endif -%}
      </div>

      {%- render 'lc-curtain-swatch-gallery', profile: profile, integrated: true -%}
    </div>
  </section>
{%- endif -%}
