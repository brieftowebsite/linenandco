{% doc %}
Renders an editorial comparison of eyelet and taped curtain headings.

@param {product} product - Current curtain product.
@param {string} current_heading - Eyelet or Taped when known.
{% enddoc %}

{%- assign eyelet_media = blank -%}
{%- assign taped_media = blank -%}
{%- for media in product.media -%}
  {%- assign media_alt_down = media.alt | downcase -%}
  {%- if eyelet_media == blank and media_alt_down contains 'eyelet' -%}
    {%- if media_alt_down contains 'product view' or media_alt_down contains 'lifestyle view' -%}
      {%- assign eyelet_media = media -%}
    {%- endif -%}
  {%- endif -%}
  {%- if taped_media == blank and media_alt_down contains 'tape' or taped_media == blank and media_alt_down contains 'taped' -%}
    {%- if media_alt_down contains 'product view' or media_alt_down contains 'lifestyle view' -%}
      {%- assign taped_media = media -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{%- if current_heading == 'Eyelet' and eyelet_media == blank -%}
  {%- assign eyelet_media = product.featured_media -%}
{%- elsif current_heading == 'Taped' and taped_media == blank -%}
  {%- assign taped_media = product.featured_media -%}
{%- endif -%}

<section class="lc-profile-section lc-curtain-heading-guide" id="lc-curtain-heading-guide">
  <div class="lc-profile-section__inner">
    <span class="lc-label">{{ 'curtain_profile.heading_guide.label' | t }}</span>
    <h2 class="lc-profile-section__heading">{{ 'curtain_profile.heading_guide.heading' | t }}</h2>
    <p class="lc-curtain-heading-guide__intro">{{ 'curtain_profile.heading_guide.intro' | t }}</p>

    <div class="lc-curtain-heading-guide__grid">
      <article class="lc-curtain-heading-option">
        {%- if eyelet_media != blank and eyelet_media.preview_image != blank -%}
          <div class="lc-curtain-heading-option__image">
            <img
              src="{{ eyelet_media.preview_image | image_url: width: 900 }}"
              srcset="{{ eyelet_media.preview_image | image_url: width: 500 }} 500w, {{ eyelet_media.preview_image | image_url: width: 700 }} 700w, {{ eyelet_media.preview_image | image_url: width: 900 }} 900w"
              sizes="(max-width: 749px) 100vw, 50vw"
              alt="{{ 'curtain_profile.heading_guide.eyelet_alt' | t: product: product.title | escape }}"
              width="900"
              height="675"
              loading="lazy">
          </div>
        {%- endif -%}
        <div class="lc-curtain-heading-option__header">
          <h3>{{ 'curtain_profile.heading_guide.eyelet' | t }}</h3>
          {%- if current_heading == 'Eyelet' -%}
            <span class="lc-curtain-heading-option__current">{{ 'curtain_profile.heading_guide.current' | t }}</span>
          {%- endif -%}
        </div>
        <p>{{ 'curtain_profile.heading_guide.eyelet_copy' | t }}</p>
        <ul>
          <li>{{ 'curtain_profile.heading_guide.eyelet_point_1' | t }}</li>
          <li>{{ 'curtain_profile.heading_guide.eyelet_point_2' | t }}</li>
          <li>{{ 'curtain_profile.heading_guide.eyelet_point_3' | t }}</li>
        </ul>
      </article>

      <article class="lc-curtain-heading-option">
        {%- if taped_media != blank and taped_media.preview_image != blank -%}
          <div class="lc-curtain-heading-option__image">
            <img
              src="{{ taped_media.preview_image | image_url: width: 900 }}"
              srcset="{{ taped_media.preview_image | image_url: width: 500 }} 500w, {{ taped_media.preview_image | image_url: width: 700 }} 700w, {{ taped_media.preview_image | image_url: width: 900 }} 900w"
              sizes="(max-width: 749px) 100vw, 50vw"
              alt="{{ 'curtain_profile.heading_guide.taped_alt' | t: product: product.title | escape }}"
              width="900"
              height="675"
              loading="lazy">
          </div>
        {%- endif -%}
        <div class="lc-curtain-heading-option__header">
          <h3>{{ 'curtain_profile.heading_guide.taped' | t }}</h3>
          {%- if current_heading == 'Taped' -%}
            <span class="lc-curtain-heading-option__current">{{ 'curtain_profile.heading_guide.current' | t }}</span>
          {%- endif -%}
        </div>
        <p>{{ 'curtain_profile.heading_guide.taped_copy' | t }}</p>
        <ul>
          <li>{{ 'curtain_profile.heading_guide.taped_point_1' | t }}</li>
          <li>{{ 'curtain_profile.heading_guide.taped_point_2' | t }}</li>
          <li>{{ 'curtain_profile.heading_guide.taped_point_3' | t }}</li>
        </ul>
      </article>
    </div>
  </div>
</section>
