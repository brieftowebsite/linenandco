{% comment %}
  ============================================================
  SNIPPET: closure-type.liquid
  Store:   Linen and Co (linenco.co.za)
  Purpose: Displays closure type images and labels on the
           Product Detail Page (PDP). Fully metafield-driven
           via the closure_types metaobject. Rendered from
           the product template / PDP section.
  Usage:   {% render 'closure-type', product: product %}
  ============================================================
{% endcomment %}

{% assign closure = product.metafields.custom.closure_types.value %}

{% if closure != blank %}
  {% assign closure_title = closure.closure_title.value %}
  {% assign closure_subtitle = closure.closure_subtitle.value %}
  {% assign closure_img_1 = closure.closure_image_1.value %}
  {% assign closure_img_1_label = closure.closure_label_1.value %}
  {% assign closure_img_2 = closure.closure_image_2.value %}
  {% assign closure_img_2_label = closure.closure_label_2.value %}

  {% if closure_img_1 or closure_img_2 %}
  <div class="closure-type">
    {% if closure_title != blank %}
      <h3 class="closure-type__title">{{ closure_title }}</h3>
    {% endif %}
    {% if closure_subtitle != blank %}
      <p class="closure-type__subtitle">{{ closure_subtitle }}</p>
    {% endif %}

    <div class="closure-type__images">
      {% if closure_img_1 %}
        <div class="closure-type__item">
          <button class="closure-type__zoom-link"
                  onclick="closureTypeOpenLightbox('closure-lb-1')"
                  aria-label="View {{ closure_img_1_label | default: 'closure image' }} enlarged">
            <div class="closure-type__img-wrap">
              <img
                src="{{ closure_img_1 | image_url: width: 600 }}"
                alt="{{ closure_img_1_label | default: 'Closure type 1' }}"
                width="600"
                height="400"
                loading="lazy"
              >
              <span class="closure-type__zoom-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                  <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
                </svg>
              </span>
            </div>
          </button>
          {% if closure_img_1_label != blank %}
            <span class="closure-type__label">{{ closure_img_1_label }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if closure_img_2 %}
        <div class="closure-type__item">
          <button class="closure-type__zoom-link"
                  onclick="closureTypeOpenLightbox('closure-lb-2')"
                  aria-label="View {{ closure_img_2_label | default: 'closure image' }} enlarged">
            <div class="closure-type__img-wrap">
              <img
                src="{{ closure_img_2 | image_url: width: 600 }}"
                alt="{{ closure_img_2_label | default: 'Closure type 2' }}"
                width="600"
                height="400"
                loading="lazy"
              >
              <span class="closure-type__zoom-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                  <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
                </svg>
              </span>
            </div>
          </button>
          {% if closure_img_2_label != blank %}
            <span class="closure-type__label">{{ closure_img_2_label }}</span>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>

  <!-- Lightbox overlays -->
  {% if closure_img_1 %}
    <div id="closure-lb-1" class="closure-type__lightbox" role="dialog" aria-modal="true" aria-label="{{ closure_img_1_label | default: 'Closure image' }}" onclick="closureTypeCloseLightbox(this)">
      <div class="closure-type__lightbox-inner" onclick="event.stopPropagation()">
        <button class="closure-type__lightbox-close" onclick="closureTypeCloseLightbox(document.getElementById('closure-lb-1'))" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <img src="{{ closure_img_1 | image_url: width: 1200 }}"
             alt="{{ closure_img_1_label | default: 'Closure type 1' }}"
             width="1200" height="800">
        {% if closure_img_1_label != blank %}
          <p class="closure-type__lightbox-caption">{{ closure_img_1_label }}</p>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if closure_img_2 %}
    <div id="closure-lb-2" class="closure-type__lightbox" role="dialog" aria-modal="true" aria-label="{{ closure_img_2_label | default: 'Closure image' }}" onclick="closureTypeCloseLightbox(this)">
      <div class="closure-type__lightbox-inner" onclick="event.stopPropagation()">
        <button class="closure-type__lightbox-close" onclick="closureTypeCloseLightbox(document.getElementById('closure-lb-2'))" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <img src="{{ closure_img_2 | image_url: width: 960 }}"
             alt="{{ closure_img_2_label | default: 'Closure type 2' }}"
             width="960" height="640">
        {% if closure_img_2_label != blank %}
          <p class="closure-type__lightbox-caption">{{ closure_img_2_label }}</p>
        {% endif %}
      </div>
    </div>
  {% endif %}

  <style>
    .closure-type {
      margin: 1.5rem 0;
      padding: 1.25rem 0;
      border-top: 1px solid #e8e8e8;
    }
    .closure-type__title {
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin: 0 0 0.25rem;
    }
    .closure-type__subtitle {
      font-size: 0.85rem;
      color: #666;
      margin: 0 0 0.75rem;
    }
    .closure-type__images {
      display: flex;
      gap: 0.75rem;
      flex-wrap: nowrap;
    }
    .closure-type__item {
      flex: 1 1 0;
      min-width: 0;
      text-align: center;
    }
    .closure-type__zoom-link {
      display: block;
      width: 100%;
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
    }
    .closure-type__img-wrap {
      position: relative;
      overflow: hidden;
      border-radius: 4px;
      border: 1px solid #e0e0e0;
    }
    .closure-type__img-wrap img {
      width: 100%;
      height: 140px;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }
    .closure-type__zoom-link:hover .closure-type__img-wrap img {
      transform: scale(1.04);
    }
    .closure-type__zoom-icon {
      position: absolute;
      bottom: 6px;
      right: 6px;
      background: rgba(255,255,255,0.85);
      border-radius: 50%;
      width: 26px;
      height: 26px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #333;
      pointer-events: none;
    }
    .closure-type__label {
      display: block;
      margin-top: 0.4rem;
      font-size: 0.78rem;
      font-weight: 500;
      color: #444;
    }

    /* Lightbox */
    .closure-type__lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.85);
      z-index: 99999;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .closure-type__lightbox.is-open {
      display: flex;
    }
    .closure-type__lightbox-inner {
      position: relative;
      background: #111;
      border-radius: 6px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .closure-type__lightbox-inner img {
      display: block;
      max-width: min(90vw, 700px);
      max-height: 85vh;
      width: auto;
      height: auto;
      object-fit: contain;
    }
    .closure-type__lightbox-close {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(255,255,255,0.9);
      border: none;
      border-radius: 50%;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 1;
      color: #111;
    }
    .closure-type__lightbox-caption {
      text-align: center;
      color: #fff;
      font-size: 0.8rem;
      padding: 0.5rem;
      margin: 0;
      background: rgba(0,0,0,0.6);
    }

    /* Mobile */
    @media (max-width: 749px) {
      .closure-type__img-wrap img { height: 100px; }
    }
  </style>

  <script>
    function closureTypeOpenLightbox(id) {
      var lb = document.getElementById(id);
      if (lb) {
        lb.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
    }
    function closureTypeCloseLightbox(el) {
      el.classList.remove('is-open');
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.closure-type__lightbox.is-open').forEach(function(lb) {
          closureTypeCloseLightbox(lb);
        });
      }
    });
  </script>
  {% endif %}
{% endif %}




