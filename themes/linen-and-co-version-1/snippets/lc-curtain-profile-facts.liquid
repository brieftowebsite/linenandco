{% doc %}
Renders the technical details stored on the assigned curtain_profile metaobject.

@param {object} profile - Curtain profile metaobject.
{% enddoc %}

{%- liquid
  assign composition = profile.composition.value | default: profile.composition
  assign fabric_weight = profile.fabric_weight.value | default: profile.fabric_weight
  assign weave_type = profile.weave_type.value | default: profile.weave_type
  assign lining_type = profile.lining_type.value | default: profile.lining_type
  assign light_control = profile.light_control.value | default: profile.light_control
  assign width_drop_options = profile.width_drop_options.value | default: profile.width_drop_options
  assign laundry_rating = profile.laundry_rating.value | default: profile.laundry_rating
  assign drying_method = profile.drying_method.value | default: profile.drying_method
  assign sustainability_note = profile.sustainability_note.value | default: profile.sustainability_note
  assign available_colours = profile.available_colours.value | default: profile.available_colours
  assign range = profile.range.value | default: profile.range
  assign current_heading_style = profile.current_heading_style.value | default: profile.current_heading_style

  assign has_details = false
  if range != blank or available_colours != blank or current_heading_style != blank or composition != blank or fabric_weight != blank or weave_type != blank or lining_type != blank or light_control != blank or width_drop_options != blank or laundry_rating != blank or drying_method != blank or sustainability_note != blank
    assign has_details = true
  endif
-%}

{%- if has_details -%}
  <section class="lc-curtain-section lc-curtain-details" id="lc-curtain-details">
    <div class="lc-curtain-section__inner">
      <div class="lc-curtain-title-row">
        <span class="lc-curtain-kicker">Curtain Details</span>
        <h2>At a glance</h2>
      </div>

      <div class="lc-curtain-detail-grid">
        {%- if range != blank -%}<div class="lc-curtain-detail"><span>Range</span><strong>{{ range | escape }}</strong></div>{%- endif -%}
        {%- if available_colours != blank -%}<div class="lc-curtain-detail"><span>Available colours</span><strong>{{ available_colours | escape }}</strong></div>{%- endif -%}
        {%- if current_heading_style != blank -%}<div class="lc-curtain-detail"><span>Heading style</span><strong>{{ current_heading_style | capitalize | escape }}</strong></div>{%- endif -%}
        {%- if composition != blank -%}<div class="lc-curtain-detail"><span>Composition</span><strong>{{ composition | escape }}</strong></div>{%- endif -%}
        {%- if fabric_weight != blank -%}<div class="lc-curtain-detail"><span>Fabric weight</span><strong>{{ fabric_weight | escape }}</strong></div>{%- endif -%}
        {%- if weave_type != blank -%}<div class="lc-curtain-detail"><span>Weave type</span><strong>{{ weave_type | escape }}</strong></div>{%- endif -%}
        {%- if lining_type != blank -%}<div class="lc-curtain-detail"><span>Lining type</span><strong>{{ lining_type | escape }}</strong></div>{%- endif -%}
        {%- if light_control != blank -%}<div class="lc-curtain-detail"><span>Light control</span><strong>{{ light_control | escape }}</strong></div>{%- endif -%}
        {%- if width_drop_options != blank -%}<div class="lc-curtain-detail"><span>Width / drop options</span><strong>{{ width_drop_options | escape }}</strong></div>{%- endif -%}
        {%- if laundry_rating != blank -%}<div class="lc-curtain-detail"><span>Laundry rating</span><strong>{{ laundry_rating | escape }}</strong></div>{%- endif -%}
        {%- if drying_method != blank -%}<div class="lc-curtain-detail"><span>Drying method</span><strong>{{ drying_method | escape }}</strong></div>{%- endif -%}
        {%- if sustainability_note != blank -%}<div class="lc-curtain-detail"><span>Sustainability note</span><strong>{{ sustainability_note | escape }}</strong></div>{%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}
