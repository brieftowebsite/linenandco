{% assign faq = product.metafields.custom.faq.value %}
{% if faq != blank %}
  <div class="product-faq">
    <p class="product-faq__label">Frequently Asked Questions</p>
    <div class="product-faq__list">
      {% for item in faq %}
        <details class="product-faq__item">
          <summary class="product-faq__question">{{ item.question }}</summary>
          <div class="product-faq__answer rte">{{ item.answer }}</div>
        </details>
      {% endfor %}
    </div>
  </div>
{% endif %}

<style>
  .product-faq { margin: 16px 0; }
  .product-faq__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 10px;
    color: rgba(0,0,0,0.5);
  }
  .product-faq__item {
    border-top: 1px solid rgba(0,0,0,0.1);
    padding: 12px 0;
  }
  .product-faq__item:last-child { border-bottom: 1px solid rgba(0,0,0,0.1); }
  .product-faq__question {
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: rgba(0,0,0,0.8);
  }
  .product-faq__question::-webkit-details-marker { display: none; }
  .product-faq__question::after {
    content: '+';
    font-size: 1.1rem;
    font-weight: 300;
    color: rgba(0,0,0,0.4);
  }
  details[open] .product-faq__question::after { content: '−'; }
  .product-faq__answer {
    font-size: 0.85rem;
    color: rgba(0,0,0,0.65);
    line-height: 1.6;
    padding-top: 8px;
  }
</style>
