{% doc %}
  Renders a standalone product FAQ section when the product references a FAQ
  metaobject with a non-blank rich-text answer field.

  @param {product} product - The current Shopify product.
{% enddoc %}

{%- liquid
  assign faq_entry = product.metafields.custom.faq.value
  assign faq_heading = faq_entry.question.value | default: faq_entry.question | strip
  assign faq_answer = faq_entry.answer
  assign faq_answer_value = faq_answer.value | default: faq_answer
-%}

{%- if faq_entry != blank and faq_answer_value != blank -%}
  <section class="lc-profile-section lc-product-faq" id="lc-faq" aria-labelledby="lc-faq-heading">
    <div class="lc-product-faq__inner">
      <span class="lc-label">{{ 'curtain_profile.faq.label' | t }}</span>
      <h2 class="lc-profile-section__heading lc-product-faq__heading" id="lc-faq-heading">
        {%- if faq_heading != blank -%}
          {{ faq_heading | escape }}
        {%- else -%}
          {{ 'curtain_profile.faq.heading' | t }}
        {%- endif -%}
      </h2>

      <div class="lc-product-faq__content rte">
        {{ faq_answer | metafield_tag }}
      </div>
    </div>
  </section>
{%- endif -%}
