{% doc %}
  Renders a standalone product FAQ section when the product FAQ metafield
  contains at least one complete question-and-answer pair.

  @param {product} product - The current Shopify product.
{% enddoc %}

{%- liquid
  assign faq_items = product.metafields.custom.faq.value
  assign has_valid_faq = false

  for item in faq_items
    assign item_question = item.question.value | default: item.question | strip
    assign item_answer = item.answer.value | default: item.answer
    assign item_answer_html = item_answer.html | default: item.answer.html | default: item_answer

    if item_question != blank and item_answer_html != blank
      assign has_valid_faq = true
      break
    endif
  endfor
-%}

{%- if has_valid_faq -%}
  <section class="lc-profile-section lc-product-faq" id="lc-faq" aria-labelledby="lc-faq-heading">
    <div class="lc-product-faq__inner">
      <span class="lc-label">{{ 'curtain_profile.faq.label' | t }}</span>
      <h2 class="lc-profile-section__heading lc-product-faq__heading" id="lc-faq-heading">
        {{ 'curtain_profile.faq.heading' | t }}
      </h2>

      <div class="lc-product-faq__list">
        {%- for item in faq_items -%}
          {%- liquid
            assign item_question = item.question.value | default: item.question | strip
            assign item_answer = item.answer.value | default: item.answer
            assign item_answer_html = item_answer.html | default: item.answer.html | default: item_answer
          -%}

          {%- if item_question != blank and item_answer_html != blank -%}
            <details class="lc-product-faq__item">
              <summary class="lc-product-faq__question">
                <span>{{ item_question | escape }}</span>
              </summary>
              <div class="lc-product-faq__answer rte">
                {%- if item_answer.html != blank or item.answer.html != blank -%}
                  {{ item_answer_html }}
                {%- else -%}
                  {{ item_answer_html | newline_to_br }}
                {%- endif -%}
              </div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}
