{% assign styles = product.metafields.custom.styles.value %}
{% if styles != blank %}

  <div class="lc-style-compare">
    <div class="lc-style-compare__header">
      {% if styles.title != blank %}
        <h2 class="lc-style-compare__title">{{ styles.title }}</h2>
      {% endif %}
      {% if styles.intro != blank %}
        <p class="lc-style-compare__intro">{{ styles.intro }}</p>
      {% endif %}
    </div>

    <div class="lc-style-compare__grid">

      {% assign i = 1 %}
      {% for i in (1..5) %}
        {% assign label_key = 'label_' | append: i %}
        {% assign image_key = 'image_' | append: i %}
        {% assign label = styles[label_key] %}
        {% assign image = styles[image_key] %}
        {% if label != blank or image != blank %}
          <div class="lc-style-compare__item">
            {% if image != blank %}
              <div class="lc-style-compare__img-wrap">
                <img
                  src="{{ image | image_url: width: 600 }}"
                  alt="{{ label | default: 'Style option' }}"
                  width="600"
                  height="600"
                  loading="lazy"
                >
              </div>
            {% endif %}
            {% if label != blank %}
              <p class="lc-style-compare__label">{{ label }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

    </div>
  </div>

  <style>
    .lc-style-compare {
      margin: 32px 0;
      width: 100%;
    }

    .lc-style-compare__header {
      text-align: center;
      margin-bottom: 24px;
    }

    .lc-style-compare__title {
      font-size: clamp(1.2rem, 3vw, 1.6rem);
      font-weight: 600;
      margin: 0 0 8px;
      color: rgba(0,0,0,0.85);
    }

    .lc-style-compare__intro {
      font-size: 0.85rem;
      font-style: italic;
      color: rgba(0,0,0,0.55);
      margin: 0;
      line-height: 1.6;
    }

    .lc-style-compare__grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
    }

    .lc-style-compare__item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    .lc-style-compare__img-wrap {
      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 4px;
      background: rgba(0,0,0,0.04);
    }

    .lc-style-compare__img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }

    .lc-style-compare__img-wrap img:hover {
      transform: scale(1.03);
    }

    .lc-style-compare__label {
      font-size: 0.78rem;
      text-align: center;
      color: rgba(0,0,0,0.7);
      margin: 0;
      line-height: 1.4;
    }

    @media (max-width: 749px) {
      .lc-style-compare__grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }
      .lc-style-compare__title {
        font-size: 1.1rem;
      }
    }
  </style>

{% endif %}
