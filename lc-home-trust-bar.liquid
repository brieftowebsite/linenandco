{%- liquid
  assign rating_value = section.settings.rating_value | default: '4.72'
  assign review_count = section.settings.review_count | default: '25'
  assign reviews_link = section.settings.reviews_link
-%}

<section class="lc-home-trust-bar" style="--lc-trust-bg: {{ section.settings.background }}; --lc-trust-text: {{ section.settings.text_color }}; --lc-trust-muted: {{ section.settings.muted_color }}; --lc-trust-star: {{ section.settings.star_color }};">
  <div class="container">
    <ul class="lc-home-trust-bar__inner">
      <li class="lc-home-trust-bar__cell lc-home-trust-bar__cell--rating">
      {%- if reviews_link != blank -%}
        <a class="lc-home-trust-bar__cell-link" href="{{ reviews_link }}">
      {%- else -%}
        <div class="lc-home-trust-bar__cell-link">
      {%- endif -%}
        <span class="lc-home-trust-bar__stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            <svg viewBox="0 0 20 20" focusable="false">
              <path d="m10 1.5 2.43 5.28 5.77.68-4.27 3.94 1.13 5.7L10 14.25 4.94 17.1l1.13-5.7L1.8 7.46l5.77-.68L10 1.5Z" />
            </svg>
          {%- endfor -%}
        </span>

        <span class="lc-home-trust-bar__rating-copy">
          <strong><span class="lc-home-trust-bar__rating-value">{{ rating_value }}</span> Rating</strong>
          <span>
            {{ review_count }} Verified Reviews
            <svg class="lc-home-trust-bar__check" viewBox="0 0 20 20" focusable="false" aria-hidden="true">
              <path d="M7.9 13.3 4.6 10l1.2-1.2 2.1 2.1 6.3-6.3 1.2 1.2-7.5 7.5Z" />
            </svg>
          </span>
        </span>
      {%- if reviews_link != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
      </li>

      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- liquid
            assign item_link = block.settings.link
            assign icon = block.settings.icon
          -%}

          <li class="lc-home-trust-bar__cell" {{ block.shopify_attributes }}>
            {%- if item_link != blank -%}
              <a class="lc-home-trust-bar__cell-link" href="{{ item_link }}">
            {%- else -%}
              <div class="lc-home-trust-bar__cell-link">
            {%- endif -%}
            <span class="lc-home-trust-bar__icon" aria-hidden="true">
              {%- case icon -%}
                {%- when 'hospitality' -%}
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M5 20V5.8C5 4.8 5.8 4 6.8 4h7.4c1 0 1.8.8 1.8 1.8V20" />
                    <path d="M3.5 20h17" />
                    <path d="M8 8h1.7M12.3 8H14M8 11.2h1.7M12.3 11.2H14M8 14.4h1.7M12.3 14.4H14" />
                    <path d="M17 9h1.2c1 0 1.8.8 1.8 1.8V20" />
                  </svg>
                {%- when 'made' -%}
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M4.8 6.2a2.4 2.4 0 1 0 4.8 0 2.4 2.4 0 0 0-4.8 0Z" />
                    <path d="M4.8 17.8a2.4 2.4 0 1 0 4.8 0 2.4 2.4 0 0 0-4.8 0Z" />
                    <path d="M9 8.1 20 18.8" />
                    <path d="M9 15.9 20 5.2" />
                    <path d="M12.2 12h.1" />
                  </svg>
                {%- when 'delivery' -%}
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M3.5 7h10.8v9.2H3.5V7Z" />
                    <path d="M14.3 10h3.2l3 3.2v3h-6.2V10Z" />
                    <path d="M6.8 18.8a1.7 1.7 0 1 0 0-3.4 1.7 1.7 0 0 0 0 3.4ZM17.6 18.8a1.7 1.7 0 1 0 0-3.4 1.7 1.7 0 0 0 0 3.4Z" />
                    <path d="M6.3 4.8h5.4" />
                  </svg>
                {%- when 'secure' -%}
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M12 3.5 19 6.6v4.9c0 4.1-2.7 7.7-7 9-4.3-1.3-7-4.9-7-9V6.6l7-3.1Z" />
                  </svg>
                {%- when 'years' -%}
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M6 4.5h12v15H6v-15Z" />
                    <path d="M8.5 3v3M15.5 3v3M6 9h12" />
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="m12 3.5 2.6 5.3 5.9.8-4.2 4.1 1 5.8-5.3-2.8-5.3 2.8 1-5.8-4.2-4.1 5.9-.8L12 3.5Z" />
                  </svg>
              {%- endcase -%}
            </span>

            <span class="lc-home-trust-bar__item-copy">
              {%- if block.settings.title != blank -%}
                <strong>{{ block.settings.title }}</strong>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <span>{{ block.settings.text }}</span>
              {%- endif -%}
            </span>
          {%- if item_link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "LC trust bar",
  "class": "shopify-section--lc-home-trust-bar",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#151515"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#cfcfcf"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#d4af37"
    },
    {
      "type": "text",
      "id": "rating_value",
      "label": "Rating value",
      "default": "4.72"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "25"
    },
    {
      "type": "url",
      "id": "reviews_link",
      "label": "Reviews link"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {
              "value": "reviews",
              "label": "Reviews"
            },
            {
              "value": "hospitality",
              "label": "Hospitality"
            },
            {
              "value": "made",
              "label": "Made to order"
            },
            {
              "value": "delivery",
              "label": "Delivery"
            },
            {
              "value": "secure",
              "label": "Secure"
            },
            {
              "value": "years",
              "label": "Years trading"
            }
          ],
          "default": "hospitality"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Trusted by Hospitality"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Guesthouses, lodges & hotels"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LC trust bar",
      "blocks": [
        {
          "type": "trust_item"
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "made",
            "title": "Made to Order",
            "text": "Custom sizing and finishes"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "delivery",
            "title": "Nationwide Delivery",
            "text": "Across South Africa"
          }
        }
      ]
    }
  ]
}
{% endschema %}
