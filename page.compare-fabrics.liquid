{% comment %}
  Compare Fabrics Page
  Template: page.compare-fabrics.liquid
{% endcomment %}

{% assign fabrics = shop.metaobjects.fabric_profile.values %}

<div class="compare-fabrics-page">

  <div class="compare-header">
    <h1 class="compare-title">Compare Fabrics</h1>
    <p class="compare-subtitle">Find the right linen for your property — from polycotton to premium cotton percale.</p>
  </div>

  {% if fabrics.size > 0 %}
  <div class="compare-table-wrap">
    <table class="compare-table">
      <thead>
        <tr>
          <th class="compare-row-label"></th>
          {% for fabric in fabrics %}
          <th class="compare-col-head">
            {% if fabric.hero_image != blank %}
              <img
                src="{{ fabric.hero_image | image_url: width: 1720 }}"
                alt="{{ fabric.fabric_name }}"
                class="compare-fabric-img"
                width="1720"
                height="800"
                loading="lazy"
              >
            {% endif %}
            <span class="compare-fabric-name">{{ fabric.fabric_name }}</span>
            {% if fabric.subtitle != blank %}
              <span class="compare-fabric-subtitle">{{ fabric.subtitle }}</span>
            {% endif %}
            {% if fabric.shop_collection != blank %}
              <a href="{{ fabric.shop_collection }}" class="compare-shop-btn">Shop Now</a>
            {% endif %}
          </th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>

        <tr class="compare-row">
          <td class="compare-row-label">Thread Count</td>
          {% for fabric in fabrics %}
          <td class="compare-cell">
            {% if fabric.thread_count != blank %}
              <span class="compare-value-large">{{ fabric.thread_count }}</span>
              <span class="compare-value-unit">TC</span>
            {% else %}—{% endif %}
          </td>
          {% endfor %}
        </tr>

        <tr class="compare-row">
          <td class="compare-row-label">Composition</td>
          {% for fabric in fabrics %}
          <td class="compare-cell">{{ fabric.composition | default: '—' }}</td>
          {% endfor %}
        </tr>

        <tr class="compare-row">
          <td class="compare-row-label">Weave</td>
          {% for fabric in fabrics %}
          <td class="compare-cell">{{ fabric.weave_type | default: '—' }}</td>
          {% endfor %}
        </tr>

        <tr class="compare-row">
          <td class="compare-row-label">Wash Temperature</td>
          {% for fabric in fabrics %}
          <td class="compare-cell">{{ fabric.wash_temperature | default: '—' }}</td>
          {% endfor %}
        </tr>

        <tr class="compare-row">
          <td class="compare-row-label">Drying</td>
          {% for fabric in fabrics %}
          <td class="compare-cell">{{ fabric.drying_method | default: '—' }}</td>
          {% endfor %}
        </tr>

        <tr class="compare-row">
          <td class="compare-row-label">Laundry Rating</td>
          {% for fabric in fabrics %}
          <td class="compare-cell">{{ fabric.laundry_rating | default: '—' }}</td>
          {% endfor %}
        </tr>

        <tr class="compare-row">
          <td class="compare-row-label">Hypoallergenic</td>
          {% for fabric in fabrics %}
          <td class="compare-cell">
            {% if fabric.hypoallergenic == true %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="compare-check"><polyline points="20 6 9 17 4 12"/></svg>
            {% else %}
              <span class="compare-dash">—</span>
            {% endif %}
          </td>
          {% endfor %}
        </tr>

        <tr class="compare-row">
          <td class="compare-row-label">Sustainability</td>
          {% for fabric in fabrics %}
          <td class="compare-cell">{{ fabric.sustainability_note | default: '—' }}</td>
          {% endfor %}
        </tr>

      </tbody>
    </table>
  </div>
  {% else %}
    <p class="compare-empty">No fabric profiles found. Please check your metaobject entries.</p>
  {% endif %}

</div>

<div class="compare-cta-block">
  <p class="compare-cta-eyebrow">We're Here to Help</p>
  <h2 class="compare-cta-title">Need Advice?</h2>
  <p class="compare-cta-subtitle">Our team is on hand to help you find the right linen for your property, project, or home.</p>
  <div class="compare-cta-buttons">
    <a href="/pages/contact" class="compare-cta-btn compare-cta-btn--outline">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Contact Us
    </a>
    <a href="/pages/trade-registration-form" class="compare-cta-btn compare-cta-btn--outline">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Trade Login
    </a>
    <a href="https://wa.me/27662918292" class="compare-cta-btn compare-cta-btn--whatsapp" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      Chat on WhatsApp
    </a>
  </div>
</div>

<style>
.compare-fabrics-page {
  max-width: 1200px;
  margin: 0 auto;
  padding: 48px 24px 24px;
}
.compare-header {
  text-align: center;
  margin-bottom: 24px;
}
.compare-title {
  font-size: 1.6rem;
  font-weight: 500;
  letter-spacing: 0.01em;
  margin-bottom: 8px;
}
.compare-subtitle {
  font-size: 14px;
  color: #000000ff;
  white-space: nowrap;
  margin: 0 auto;
  line-height: 1.5;
}
.compare-table-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.compare-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 600px;
}
.compare-table thead tr {
  border-bottom: 1px solid #1a1a1a;
}
.compare-col-head {
  text-align: center;
  padding: 0 8px 20px;
  vertical-align: top;
  min-width: 200px;
}
.compare-fabric-img {
  display: block;
  width: 100%;
  height: auto;
  aspect-ratio: 1720 / 800;
  object-fit: cover;
  object-position: center;
  margin: 0 0 0px 0;
  border-radius: 4px;
}
.compare-fabric-name {
  display: block;
  font-size: 12px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #1a1a1a;
  margin-bottom: 4px;
}
.compare-fabric-subtitle {
  display: block;
  font-size: 11px;
  color: #222222ff;
  line-height: 1.4;
  margin-bottom: 10px;
}
.compare-shop-btn {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #1a1a1a;
  border-bottom: 1px solid #1a1a1a;
  padding-bottom: 1px;
  text-decoration: none;
}
.compare-row-label {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #1a1a1a;
  padding: 18px 16px 18px 0;
  white-space: nowrap;
  vertical-align: middle;
  width: 140px;
}
.compare-row { border-bottom: 1px solid #e8e8e8; }
.compare-row:last-child { border-bottom: none; }
.compare-cell {
  text-align: center;
  font-size: 13px;
  color: #333;
  padding: 16px 8px;
  vertical-align: middle;
  line-height: 1.4;
}
.compare-cell--range { font-size: 11px; color: #525252ff; }
.compare-value-large {
  font-size: 22px;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: -0.02em;
}
.compare-value-unit { font-size: 11px; color: #000000ff; margin-left: 2px; }
.compare-check {
  width: 18px;
  height: 18px;
  color: #1a1a1a;
  display: inline-block;
  vertical-align: middle;
}
.compare-dash { color: #000000ff; }
.compare-empty {
  text-align: center;
  font-weight: 600;
  color: #000000ff;
  font-size: 14px;
  padding: 48px 0;
}
.compare-cta-block {
  background: #1a1a1a;
  color: #000000ff;
  text-align: center;
  padding: 40px 24px;
  margin-top: 48px;
}
.compare-cta-eyebrow {
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #fefefeff;
  margin-bottom: 8px;
}
.compare-cta-title {
  font-size: 1.4rem;
  font-weight: 500;
  letter-spacing: -0.01em;
  margin-bottom: 8px;
  color: #ffffffff;
}
.compare-cta-subtitle {
  font-size: 13px;
  color: #ffffffff;
  max-width: 420px;
  margin: 0 auto 24px;
  line-height: 1.5;
}
.compare-cta-buttons {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}
.compare-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 10px 16px;
  border-radius: 2px;
  text-decoration: none;
  transition: opacity 0.2s;
}
.compare-cta-btn:hover { opacity: 0.75; }
.compare-cta-btn--outline {
  border: 1px solid #fff;
  color: #fff;
  background: transparent;
}
.compare-cta-btn--whatsapp {
  background: #25D366;
  color: #fff;
  border: 1px solid #25D366;
}
@media (max-width: 749px) {
  .compare-fabrics-page { padding: 32px 16px 16px; }
  .compare-subtitle { white-space: normal; }
  .compare-row-label { width: 100px; font-size: 10px; }
  .compare-cell { font-size: 12px; padding: 12px 6px; }
  .compare-col-head { min-width: 130px; padding: 0 4px 16px; }
  .compare-fabric-img { aspect-ratio: 16 / 9; }
  .compare-cta-block { padding: 32px 16px; }
}
</style>

