<section class="lc-about-page color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
  <div class="container">
    <div class="lc-about-page__proof" aria-label="Linen and Co proof points">
      <div>
        <span class="lc-about-page__proof-icon">{%- render 'icon' with 'picto-building', width: 28 -%}</span>
        <strong>Hospitality & trade</strong>
        <span>for guesthouses, lodges, hotels and designers</span>
      </div>
      <div>
        <span class="lc-about-page__proof-icon">{%- render 'icon' with 'picto-document', width: 28 -%}</span>
        <strong>Made to order</strong>
        <span>with sizing, closures and finishes confirmed upfront</span>
      </div>
      <div>
        <span class="lc-about-page__proof-icon">{%- render 'icon' with 'picto-award-gift', width: 28 -%}</span>
        <strong>Custom finishing</strong>
        <span>satin stitch, embroidery, labels and branding</span>
      </div>
      <div>
        <span class="lc-about-page__proof-icon">{%- render 'icon' with 'picto-customer-support', width: 28 -%}</span>
        <strong>Direct support</strong>
        <span>from enquiry to quote, delivery and reorder</span>
      </div>
    </div>

    <div class="lc-about-page__grid">
      <article>
        <h3>Made for real use</h3>
        <p>Our ranges are chosen for repeated laundering, guest turnover, everyday comfort and the clean presentation that good rooms need.</p>
      </article>
      <article>
        <h3>Clear guidance</h3>
        <p>We help you compare fabrics, sizes, quantities, lead times and care requirements before you commit to a product or project order.</p>
      </article>
      <article>
        <h3>Custom where it counts</h3>
        <p>Custom sizing, satin stitch, embroidery and labels give homes and hospitality spaces a finished, consistent and more personal result.</p>
      </article>
    </div>

    <div class="lc-about-page__split">
      <div class="lc-about-page__media">
        <img
          src="https://cdn.shopify.com/s/files/1/0931/8347/5996/files/white-folded-bed-linen-for-linen-and-co-polycotton-percale-200tc-landscape.webp"
          alt="Folded white hotel linen from Linen and Co"
          loading="lazy"
          width="900"
          height="600"
        >
      </div>
      <div class="lc-about-page__content">
        <p class="lc-about-page__eyebrow">How we work</p>
        <h2>A cleaner process from first question to future reorder.</h2>
        <ol>
          <li><strong>Tell us the room or project:</strong> products, sizes, quantities, finish, budget and deadline.</li>
          <li><strong>We match the right specification:</strong> fabric, closure, sizing, care and lead-time guidance.</li>
          <li><strong>Quote and confirm:</strong> pricing, quantities and production details are checked before anything is made.</li>
          <li><strong>Make, deliver and support:</strong> we help with reorders, replacements and practical aftercare.</li>
        </ol>
        <div class="lc-about-page__actions">
          <a href="/pages/hospitality" class="button">Hospitality hub</a>
          <a href="/pages/quotation-request" class="button button--outline">Request a quote</a>
        </div>
      </div>
    </div>

    <div class="lc-about-page__team">
      <div class="lc-about-page__section-header">
        <p class="lc-about-page__eyebrow">The people behind the orders</p>
        <h2>Small team, direct accountability</h2>
        <p>When you need an answer, you speak to people who understand the products, the order details and the reason timing matters.</p>
      </div>

      <div class="lc-about-page__team-grid" role="list">
        <article role="listitem">
          <img src="https://cdn.shopify.com/s/files/1/0931/8347/5996/files/meet-the-team-dawn-linen-and-co-3.webp?v=1768148593" alt="Dawn from Linen and Co" loading="lazy" width="380" height="380">
          <h3>Dawn</h3>
          <p>Key Account Manager</p>
          <span>Hospitality guidance, quotes and trade reorders.</span>
        </article>
        <article role="listitem">
          <img src="https://cdn.shopify.com/s/files/1/0931/8347/5996/files/meet-the-team-dean-linen-and-co.webp?v=1768148609" alt="Dean from Linen and Co" loading="lazy" width="380" height="380">
          <h3>Dean</h3>
          <p>Operations Manager</p>
          <span>Production planning, quality checks and delivery coordination.</span>
        </article>
        <article role="listitem">
          <img src="https://cdn.shopify.com/s/files/1/0931/8347/5996/files/meet-the-team-luyanda-linen-and-co.webp?v=1768148594" alt="Luyanda from Linen and Co" loading="lazy" width="380" height="380">
          <h3>Luyanda</h3>
          <p>Office Manager / Sales Assistant</p>
          <span>Order updates, client care and follow-through.</span>
        </article>
      </div>
    </div>

    <div class="lc-about-page__sustainability">
      <div>
        <p class="lc-about-page__eyebrow">Responsible where it matters</p>
        <h2>Buy the right thing once, care for it properly, replace less often.</h2>
      </div>
      <ul role="list">
        <li>Made-to-order production helps reduce unnecessary overstock and incorrect sizing.</li>
        <li>Better fabric and specification choices support longer product life.</li>
        <li>Care guidance helps linen last in both commercial and home laundering.</li>
        <li>Clear reordering helps customers replace what is needed instead of starting from scratch.</li>
      </ul>
    </div>

    <div class="lc-about-page__cta">
      <h2>Ready to source properly?</h2>
      <p>Tell us what you need and we will help you choose the right range, size, finish and route to order.</p>
      <div class="lc-about-page__actions">
        <a href="/pages/trade-registration-form" class="button">Register for trade</a>
        <a href="/pages/contact" class="button button--outline">Contact us</a>
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": "https://www.linenco.co.za/pages/about-linen-and-co#webpage",
  "url": "https://www.linenco.co.za/pages/about-linen-and-co",
  "name": "About Linen and Co",
  "description": "Linen and Co supplies hotel-quality bed linen, bath linen, table linen, window treatments and custom textile finishes for homes, hospitality and trade customers across South Africa.",
  "isPartOf": {
    "@id": "https://www.linenco.co.za/#website"
  },
  "about": {
    "@id": "https://www.linenco.co.za/#organization"
  }
}
</script>

<style>
  #shopify-section-{{ section.id }} .lc-about-page {
    padding: clamp(28px, 4vw, 44px) 0 clamp(46px, 5vw, 62px);
  }

  #shopify-section-{{ section.id }} .lc-about-page__section-header,
  #shopify-section-{{ section.id }} .lc-about-page__cta {
    max-width: 860px;
    margin: 0 auto;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .lc-about-page__eyebrow {
    margin: 0 0 10px;
    color: rgb(var(--text-color) / 0.62);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3,
  #shopify-section-{{ section.id }} p {
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .lc-about-page__content h2,
  #shopify-section-{{ section.id }} .lc-about-page__section-header h2,
  #shopify-section-{{ section.id }} .lc-about-page__sustainability h2,
  #shopify-section-{{ section.id }} .lc-about-page__cta h2 {
    margin-bottom: 14px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__proof {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin: 0 0 clamp(30px, 4vw, 46px);
    border: 1px solid rgb(var(--text-color) / 0.12);
    background: rgb(var(--text-color) / 0.12);
  }

  #shopify-section-{{ section.id }} .lc-about-page__proof div {
    display: grid;
    gap: 7px;
    min-height: 94px;
    align-content: center;
    padding: 18px;
    background: rgb(var(--background));
    text-align: center;
  }

  #shopify-section-{{ section.id }} .lc-about-page__proof strong {
    font-size: 1.05rem;
  }

  #shopify-section-{{ section.id }} .lc-about-page__proof-icon {
    display: inline-grid;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    margin: 0 auto 0.1rem;
    color: rgb(var(--text-color) / 0.82);
  }

  #shopify-section-{{ section.id }} .lc-about-page__proof-icon svg {
    width: 1.75rem;
    height: 1.75rem;
  }

  #shopify-section-{{ section.id }} .lc-about-page__proof span,
  #shopify-section-{{ section.id }} .lc-about-page__grid p,
  #shopify-section-{{ section.id }} .lc-about-page__section-header p,
  #shopify-section-{{ section.id }} .lc-about-page__cta p,
  #shopify-section-{{ section.id }} .lc-about-page__team-grid span {
    color: rgb(var(--text-color) / 0.72);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .lc-about-page__grid,
  #shopify-section-{{ section.id }} .lc-about-page__team-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__grid article,
  #shopify-section-{{ section.id }} .lc-about-page__team-grid article {
    border: 1px solid rgb(var(--text-color) / 0.13);
    border-radius: 8px;
    padding: 24px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__grid h3,
  #shopify-section-{{ section.id }} .lc-about-page__team-grid h3 {
    margin-bottom: 9px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__split,
  #shopify-section-{{ section.id }} .lc-about-page__sustainability {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 34px;
    align-items: center;
    margin-top: 42px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__media img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__content ol,
  #shopify-section-{{ section.id }} .lc-about-page__sustainability ul {
    display: grid;
    gap: 12px;
    margin: 0;
    padding-left: 1.2rem;
    color: rgb(var(--text-color) / 0.76);
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .lc-about-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 20px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__cta .lc-about-page__actions {
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .lc-about-page__team {
    margin-top: 48px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__team-grid {
    margin-top: 24px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__team-grid article {
    text-align: center;
  }

  #shopify-section-{{ section.id }} .lc-about-page__team-grid img {
    display: block;
    width: 154px;
    height: 154px;
    margin: 0 auto 14px;
    border-radius: 50%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .lc-about-page__team-grid p {
    margin-bottom: 8px;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .lc-about-page__sustainability {
    padding: 28px;
    border: 1px solid rgb(var(--text-color) / 0.13);
    border-radius: 8px;
  }

  #shopify-section-{{ section.id }} .lc-about-page__cta {
    margin-top: 48px;
    padding-top: 34px;
    border-top: 1px solid rgb(var(--text-color) / 0.13);
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .lc-about-page {
      padding: 34px 0 42px;
    }

    #shopify-section-{{ section.id }} .lc-about-page__proof {
      grid-template-columns: 1fr;
      gap: 0;
      margin-bottom: 28px;
      border-inline: 0;
      background: transparent;
    }

    #shopify-section-{{ section.id }} .lc-about-page__proof div {
      grid-template-columns: 2rem minmax(0, 1fr);
      column-gap: 0.75rem;
      row-gap: 0.16rem;
      align-items: center;
      min-height: 0;
      padding: 0.85rem 0;
      background: transparent;
      text-align: start;
      border-bottom: 1px solid rgb(var(--text-color) / 0.12);
    }

    #shopify-section-{{ section.id }} .lc-about-page__proof div:last-child {
      border-bottom: 0;
    }

    #shopify-section-{{ section.id }} .lc-about-page__proof-icon {
      grid-row: 1 / 3;
      width: 1.8rem;
      height: 1.8rem;
      margin: 0;
    }

    #shopify-section-{{ section.id }} .lc-about-page__proof-icon svg {
      width: 1.35rem;
      height: 1.35rem;
    }

    #shopify-section-{{ section.id }} .lc-about-page__proof strong {
      font-size: 0.95rem;
    }

    #shopify-section-{{ section.id }} .lc-about-page__proof div > span:not(.lc-about-page__proof-icon),
    #shopify-section-{{ section.id }} .lc-about-page__grid p,
    #shopify-section-{{ section.id }} .lc-about-page__section-header p,
    #shopify-section-{{ section.id }} .lc-about-page__cta p,
    #shopify-section-{{ section.id }} .lc-about-page__team-grid span {
      font-size: 0.88rem;
      line-height: 1.45;
    }

    #shopify-section-{{ section.id }} .lc-about-page__grid,
    #shopify-section-{{ section.id }} .lc-about-page__team-grid,
    #shopify-section-{{ section.id }} .lc-about-page__split,
    #shopify-section-{{ section.id }} .lc-about-page__sustainability {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .lc-about-page__grid article,
    #shopify-section-{{ section.id }} .lc-about-page__team-grid article,
    #shopify-section-{{ section.id }} .lc-about-page__sustainability {
      padding: 18px;
    }
  }

  @media (max-width: 699px) {
    #shopify-section-{{ section.id }} .lc-about-page {
      padding: 26px 0 38px;
    }

    #shopify-section-{{ section.id }} .lc-about-page__proof-icon {
      width: 1.7rem;
      height: 1.7rem;
      margin-bottom: 0;
    }

    #shopify-section-{{ section.id }} .lc-about-page__proof-icon svg {
      width: 1.25rem;
      height: 1.25rem;
    }

    #shopify-section-{{ section.id }} .lc-about-page__split,
    #shopify-section-{{ section.id }} .lc-about-page__sustainability {
      gap: 24px;
      margin-top: 32px;
    }

    #shopify-section-{{ section.id }} .lc-about-page__team {
      margin-top: 36px;
    }

    #shopify-section-{{ section.id }} .lc-about-page__team-grid {
      margin-top: 18px;
    }

    #shopify-section-{{ section.id }} .lc-about-page__team-grid img {
      width: 132px;
      height: 132px;
    }

    #shopify-section-{{ section.id }} .lc-about-page__actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .lc-about-page__actions .button {
      justify-content: center;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .lc-about-page__cta {
      margin-top: 36px;
      padding-top: 26px;
    }
  }
</style>

