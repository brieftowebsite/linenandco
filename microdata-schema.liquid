{%- comment -%}
  This snippet structures the micro-data using JSON-LD specification. Starting from Prestige 10, we are using
  the structured_data built-in filter to ensure that Shopify can keep it up to date without requiring theme upgrade. If
  you believe some information for products are missing, please reach Shopify support directly, as it is no longer
  managed at the theme level.
{%- endcomment -%}

{%- if request.page_type == 'product' -%}
  {%- liquid
    assign is_blind_product_schema = false
    assign product_type_downcase = product.type | downcase
    assign product_vendor_downcase = product.vendor | downcase
    assign product_template_suffix = product.template_suffix | downcase
    assign product_handle_downcase = product.handle | downcase
    assign product_tags_downcase = product.tags | join: ' ' | downcase
    assign blind_pricing_key = product.metafields.custom.blind_pricing_key.value | default: product.metafields.custom.blind_pricing_key
    assign blind_profile = product.metafields.custom.blinds.value | default: product.metafields.custom.blind_profile.value | default: product.metafields.custom.blinds_profile.value | default: product.metafields.custom.blind_product_profile.value

    if product_type_downcase contains 'blind'
      assign is_blind_product_schema = true
    elsif product_vendor_downcase contains 'focus blinds'
      assign is_blind_product_schema = true
    elsif product_template_suffix contains 'blind'
      assign is_blind_product_schema = true
    elsif product_handle_downcase contains 'blind'
      assign is_blind_product_schema = true
    elsif product_tags_downcase contains 'blind'
      assign is_blind_product_schema = true
    elsif blind_pricing_key != blank
      assign is_blind_product_schema = true
    elsif blind_profile != blank
      assign is_blind_product_schema = true
    endif
  -%}

  {%- if is_blind_product_schema -%}
    {%- capture blind_starting_price -%}
      {%- render 'lc-blind-starting-price', product: product, mode: 'amount' -%}
    {%- endcapture -%}
    {%- assign blind_starting_price = blind_starting_price | strip -%}

    {%- if blind_starting_price != blank -%}
      {%- liquid
        assign blind_description = product.description | strip_html | strip_newlines | strip
        assign blind_brand = product.vendor | default: shop.name
        assign blind_availability = 'https://schema.org/OutOfStock'
        assign blind_currency = cart.currency.iso_code | default: shop.currency

        if product.available
          assign blind_availability = 'https://schema.org/InStock'
        endif
      -%}

      <script type="application/ld+json">
        {
          "@context": "https://schema.org/",
          "@type": "Product",
          "@id": {{ canonical_url | append: "#product" | json }},
          "name": {{ product.title | json }},
          {%- if product.images.size > 0 %}
            "image": [
              {%- for image in product.images limit: 6 -%}
                {{ image | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
              {%- endfor -%}
            ],
          {%- endif %}
          "description": {{ blind_description | default: product.title | json }},
          "brand": {
            "@type": "Brand",
            "name": {{ blind_brand | json }}
          },
          {%- if product.selected_or_first_available_variant.sku != blank %}
            "sku": {{ product.selected_or_first_available_variant.sku | json }},
          {%- endif %}
          "category": {{ product.type | json }},
          "offers": {
            "@type": "Offer",
            "url": {{ canonical_url | json }},
            "priceCurrency": {{ blind_currency | json }},
            "price": {{ blind_starting_price | json }},
            "availability": {{ blind_availability | json }},
            "itemCondition": "https://schema.org/NewCondition",
            "priceSpecification": {
              "@type": "PriceSpecification",
              "price": {{ blind_starting_price | json }},
              "priceCurrency": {{ blind_currency | json }},
              "description": "Starting price for the minimum made-to-measure blind size. Final price is calculated from the selected width and drop."
            }
          }
        }
      </script>
    {%- endif -%}
  {%- else -%}
    <script type="application/ld+json">
      {{- product | structured_data -}}
    </script>
  {%- endif -%}
{%- elsif request.page_type == 'article' -%}
  <script type="application/ld+json">
    {{- article | structured_data -}}
  </script>
{%- endif -%}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [{
        "@type": "ListItem",
        "position": 1,
        "name": {{ 'general.home' | t | json }},
        "item": "{{ shop.url }}"
      }

      {%- if request.page_type == 'product' -%}
        {%- if collection -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": "{{ shop.url }}{{ collection.url }}"
          }, {
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }},
            "item": "{{ shop.url }}{{ product.url }}"
          }
        {%- else -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.title | json }},
            "item": "{{ shop.url }}{{ product.url }}"
          }
        {%- endif -%}
      {%- elsif request.page_type == 'collection' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": "{{ shop.url }}{{ collection.url }}"
          }
      {%- elsif request.page_type == 'blog' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": "{{ shop.url }}{{ blog.url }}"
          }
      {%- elsif request.page_type == 'article' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ blog.title | json }},
            "item": "{{ shop.url }}{{ blog.url }}"
          }, {
            "@type": "ListItem",
            "position": 3,
            "name": {{ article.title | json }},
            "item": "{{ shop.url }}{{ article.url }}"
          }
      {%- elsif request.page_type == 'page' -%}
        ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ page.title | json }},
            "item": "{{ shop.url }}{{ page.url }}"
          }
      {%- endif -%}
    ]
  }
</script>

