{%- liquid
  assign satin_list = product.metafields.custom.satin_stitch_colour.value
  assign picker_dom_id = 'SatinStitchSection'
  assign input_dom_id = 'lc-satin-stitch-property'
  assign picker_context_value = picker_context | default: 'main'

  if picker_id != blank
    assign picker_handle = picker_id | handleize
    assign picker_dom_id = 'SatinStitchSection-' | append: picker_handle
    assign input_dom_id = 'lc-satin-stitch-property-' | append: picker_handle
  endif
-%}

{%- if satin_list != blank -%}
  <div
    id="{{ picker_dom_id }}"
    class="lc-satin-stitch-picker"
    data-has-swatches="true"
    data-lc-satin-stitch-picker="{{ picker_context_value }}"
    {% if form_id != blank %}data-lc-satin-form-id="{{ form_id }}"{% endif %}
  >
    <div class="lc-satin-stitch-picker__header">
      <span class="lc-satin-stitch-picker__title">Satin Stitch Colour:</span>
      <span class="js-selected-stitch-label lc-satin-stitch-picker__selected"></span>
    </div>

    <div class="lc-satin-stitch-picker__swatches">
      {%- for stitch_colour in satin_list -%}
        {%- assign stitch_handle = stitch_colour.system.handle -%}
        {%- assign stitch_label = stitch_colour.label.value | default: stitch_colour['label'].value -%}
        {%- assign stitch_image = stitch_colour.image.value | default: stitch_colour['image'].value -%}

        {%- if stitch_label == blank and stitch_handle != blank -%}
          {%- assign stitch_label = stitch_handle | remove: '-satin-stitch' | replace: '-', ' ' | capitalize -%}
        {%- endif -%}

        {%- if stitch_label != blank -%}
          <button
            type="button"
            class="lc-satin-stitch-picker__swatch"
            data-stitch-label="{{ stitch_label | escape }}"
            aria-label="Satin stitch colour {{ stitch_label | escape }}"
            title="{{ stitch_label | escape }}"
          >
            {%- if stitch_image != blank -%}
              <img
                class="lc-satin-stitch-picker__swatch-img"
                src="{{ stitch_image | image_url: width: 80 }}"
                alt="{{ stitch_label | escape }}"
                width="40"
                height="40"
                loading="lazy"
              >
            {%- else -%}
              <span class="lc-satin-stitch-picker__swatch-fallback">
                {{ stitch_label | slice: 0, 1 }}
              </span>
            {%- endif -%}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <input
      id="{{ input_dom_id }}"
      type="hidden"
      {% if form_id != blank %}form="{{ form_id }}"{% endif %}
      name="properties[Satin Stitch Colour]"
      value=""
      disabled
    >
  </div>
{%- endif -%}
