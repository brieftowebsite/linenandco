      font-size: 0.92rem;
      line-height: 1.5;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__proof {
      margin: 1rem 0 1.65rem;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__proof div {
      grid-template-columns: 2rem minmax(0, 1fr);
      column-gap: 0.75rem;
      row-gap: 0.16rem;
      align-items: center;
      min-height: 0;
      padding: 0.85rem 0;
      border-right: 0;
      border-bottom: 1px solid rgb(var(--text-color) / 0.14);
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__proof-icon {
      grid-row: 1 / 3;
      width: 1.8rem;
      height: 1.8rem;
      margin: 0;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__proof-icon svg {
      width: 1.35rem;
      height: 1.35rem;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__proof strong {
      font-size: 0.95rem;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__proof div > span:not(.lc-hospitality-hub__proof-icon) {
      font-size: 0.84rem;
      line-height: 1.38;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__proof div:last-child {
      border-bottom: 0;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__route,
    #shopify-section-{{ section.id }} .lc-hospitality-hub__range-grid a {
      padding: 1rem;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__contact-actions {
      justify-content: flex-start;
    }
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .lc-hospitality-hub {
      padding-block: 1.6rem 2.4rem;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__copy h3,
    #shopify-section-{{ section.id }} .lc-hospitality-hub__section-head h3,
    #shopify-section-{{ section.id }} .lc-hospitality-hub__contact h3 {
      font-size: clamp(1.35rem, 6vw, var(--text-h3));
      line-height: 1.18;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__copy.rte,
    #shopify-section-{{ section.id }} .lc-hospitality-hub__route p,
    #shopify-section-{{ section.id }} .lc-hospitality-hub__range-grid span,
    #shopify-section-{{ section.id }} .lc-hospitality-hub__support-grid span {
      font-size: 0.9rem;
      line-height: 1.55;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__contact-actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__proof {
      margin: 1.25rem 0 2rem;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__visuals {
      display: flex;
      gap: 0.75rem;
      margin-inline: calc(-1 * max(var(--container-gutter), 1rem));
      overflow-x: auto;
      padding-inline: max(var(--container-gutter), 1rem);
      scroll-snap-type: x proximity;
      scrollbar-width: none;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__visuals::-webkit-scrollbar {
      display: none;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__visuals figure {
      flex: 0 0 min(82vw, 20rem);
      aspect-ratio: 4 / 3;
      min-height: 0;
      scroll-snap-align: start;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__visuals img {
      height: 100%;
      min-height: 0;
    }

    #shopify-section-{{ section.id }} .lc-hospitality-hub__proof div,
    #shopify-section-{{ section.id }} .lc-hospitality-hub__route,
    #shopify-section-{{ section.id }} .lc-hospitality-hub__range-grid a {
